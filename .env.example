# Copy this file to .env and fill in your values.
# All settings have sensible defaults; only override what you need.

# Path to the Indian Cricket PDF document (relative to project root)
PDF_PATH=./data/Indian_Cricket_Report.pdf

# Path to the ChromaDB persistence directory
CHROMA_DB_PATH=./chroma_db

# LLM model name (free, runs locally on CPU)
LLM_MODEL=google/flan-t5-small

# HuggingFace sentence-transformers embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Text chunking parameters
CHUNK_SIZE=1000
CHUNK_OVERLAP=250

# Number of documents to retrieve per query
RETRIEVER_K=5

# Maximum retries for hallucination / answer grading loops
MAX_RETRIES=3

# Flask API settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Streamlit settings
STREAMLIT_PORT=8501
